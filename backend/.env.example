# Server
PORT=4000
CLIENT_URL=http://localhost:5173

# Paystack — get these from https://dashboard.paystack.com/#/settings/developer
# Use test keys while developing, live keys only once you've gone through
# Paystack's business verification.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin dashboard — pick your own secret key, then enter it on the admin
# login screen to manage products and view orders.
ADMIN_KEY=change-this-to-something-only-you-know

# Where the staff admin app is served (only used when the backend also serves
# the built frontend). Keep this unguessable and don't link to it from the
# storefront. Defaults to /admin.
ADMIN_ROUTE=/admin

# Shop's own WhatsApp number (with country code, no + or spaces) — used to
# build the "notify us on WhatsApp" links customers tap after paying.
SHOP_WHATSAPP=233541533365

# Optional: SMS notifications via Arkesel (https://arkesel.com — popular
# Ghana SMS gateway). Leave blank to skip SMS and rely on WhatsApp only.
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=Cboyistore
SHOP_NOTIFY_PHONE=233541533365
